{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "dofbot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "HYDRA_FULL_ERROR": "1",
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--enable_cameras",
                "--task", "Isaac-Dofbot-v0",
                "--num_envs","1",
                "--headless"
            ]
        }
    ]
}